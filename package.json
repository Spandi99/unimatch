{
  "name": "unimatch",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:all:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1 -ExpoMode lan",
    "dev:all:linux": "bash scripts/start-dev-linux.sh",
    "dev:all:linux:lan": "bash scripts/start-dev-linux.sh --expo-mode lan",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.50.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "^54.0.0",
    "expo-file-system": "~19.0.17",
    "expo-image-picker": "~17.0.8",
    "expo-location": "~19.0.7",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.8.3"
  }
}
